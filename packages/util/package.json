{
  "name": "@grafema/util",
  "version": "0.2.12-beta",
  "description": "Query, config, and guarantee utilities for Grafema",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "cp -r src/instructions/*.md dist/instructions/",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "grafema",
    "code-analysis",
    "utilities"
  ],
  "license": "Apache-2.0",
  "author": "Vadim Reshetnikov",
  "repository": {
    "type": "git",
    "url": "https://github.com/Disentinel/grafema.git",
    "directory": "packages/util"
  },
  "dependencies": {
    "@grafema/rfdb-client": "workspace:*",
    "@grafema/types": "workspace:*",
    "ajv": "^8.17.1",
    "minimatch": "^10.1.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "typescript": "^5.9.3"
  }
}
